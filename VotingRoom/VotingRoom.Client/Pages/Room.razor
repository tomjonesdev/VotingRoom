@page "/{RoomId:guid}"
@rendermode InteractiveWebAssembly
@using Microsoft.AspNetCore.SignalR.Client
@using VotingRoom.Client.Services
@using VotingRoom.Common.Enums
@using VotingRoom.Common.Models
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IVotingService VotingService
@inject ClientStateProvider ClientState
@implements IAsyncDisposable

<PageTitle>Voting Room</PageTitle>

@* room name doesn't appear until other user joins *@
<h1>@room.Name</h1>

@if (ClientState.CurrentUser is null)
{
    <EditForm Model="voter" OnValidSubmit="JoinRoom" FormName="JoinRoom">
        <DataAnnotationsValidator />

        <label>
            Your name
            <InputText @bind-Value="voter.Name" />
            <ValidationMessage For="() => voter.Name" />
        </label>

        <br />

        <InputRadioGroup @bind-Value="voter.Type">
            @foreach (var type in Enum.GetValues<VoterType>())
            {
                <div>
                    <label>
                        <InputRadio Value="type" />
                        Join as a @type
                    </label>
                </div>
            }
        </InputRadioGroup>

        <small>Participants can vote, spectators can't</small>
        <br />
        <button class="btn btn-success">Join</button>
    </EditForm>
}
else
{
    <div class="room-description">
        <div>
            <h2>Story point voting</h2>
            <p>Simple story point voting page, using the Fibonacci sequence as a way to ascertain a task's <strong>complexity</strong>.</p>

            <button @onclick=@(() => JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", Navigation.Uri)) class="btn btn-primary">Copy room URL to clipboard</button>

            @if (voter.IsAdmin)
            {
                <button @onclick="() => VotingService.RevealVotes(RoomId)" class="btn btn-success">Reveal votes</button>
                <button @onclick="() => VotingService.ResetVotes(RoomId)" class="btn btn-danger">Reset votes</button>
            }
        </div>

        <div>
            <h3>Participants</h3>
            @if (voter.Type == VoterType.Participant)
            {
                <p>You have @voter.RemainingVotes/@room.MaxVotes votes remaining</p>
            }
            <ul>
                @foreach (var voter in room.Voters)
                {
                    <li class="text-nowrap">@voter.Name (@voter.Type) @(voter.RemainingVotes == 0 ? "✅" : "❌")</li>
                }
            </ul>
        </div>
    </div>

    <VoteCards VoteItems="voteItems" Room="room" Voter="voter" />
}

@code {
    [Parameter] public Guid RoomId { get; set; }

    Common.Models.Room room = new();
    Voter voter = new();

    List<VoteItem> voteItems =
        [
        new() { Id = 1, Name = "1" },
    new() { Id = 2, Name = "2" },
    new() { Id = 3, Name = "3" },
    new() { Id = 4, Name = "5" },
    new() { Id = 5, Name = "8" },
    new() { Id = 6, Name = "13" },
    new() { Id = 7, Name = "21" },
    ];

    protected override async Task OnInitializedAsync()
    {
        var roomId = RoomId.ToString();
        await VotingService.Connect();

        VotingService.OnUserJoined += HandleUserJoined;
        VotingService.OnUpdateCurrentUser += HandleUpdateCurrentUser;
        VotingService.OnVoteReceived += HandleVoteReceived;
        VotingService.OnRevealVotes += HandleRevealVotes;
        VotingService.OnResetVotes += HandleResetVotes;
    }

    async Task JoinRoom()
    {
        await VotingService.JoinRoom(voter, RoomId);
    }

    async Task CastVote(VoteItem voteItem)
    {
        if (voter.RemainingVotes > 0)
        {
            var vote = new Vote
            {
                Choice = voteItem,
                Voter = voter,
                RoomId = RoomId,
            };

            await VotingService.SendVote(vote);
            voter.RemainingVotes--; // move this into hub logic
        }
    }

    private void HandleUserJoined(Common.Models.Room cachedRoom)
    {
        // this isnt being triggered after create room redirection
        // second user isn't being shown the voting view (but is added to the initial user's list)
        // vote count is always 0

        InvokeAsync(() =>
        {
            room = cachedRoom;
            StateHasChanged();
        });
    }

    private void HandleUpdateCurrentUser(Voter updatedVoter)
    {
        InvokeAsync(() =>
        {
            voter = updatedVoter;
            StateHasChanged();
        });
    }

    private void HandleVoteReceived(Vote vote)
    {
        InvokeAsync(() =>
        {
            var voteItem = voteItems.First(vi => vi.Id == vote.Choice.Id);
            voteItem.Voters.Add(new() { Id = vote.Voter.Id, Name = vote.Voter.Name });
            StateHasChanged();
        });
    }

    private void HandleRevealVotes()
    {
        InvokeAsync(() =>
        {
            room.ShowVotes = true;
            StateHasChanged();
        });
    }

    private void HandleResetVotes()
    {
        InvokeAsync(() =>
        {
            voteItems.ForEach(vi => vi.Voters.Clear());
            voter.RemainingVotes = room.MaxVotes;
            room.ShowVotes = false;
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        VotingService.OnUserJoined -= HandleUserJoined;
        VotingService.OnVoteReceived -= HandleVoteReceived;
        VotingService.OnUpdateCurrentUser -= HandleUpdateCurrentUser;
        VotingService.OnRevealVotes -= HandleRevealVotes;
        VotingService.OnResetVotes -= HandleResetVotes;
    }
}
